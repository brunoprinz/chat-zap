{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the chat application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "themeColor": { "type": "string" },
        "backgroundUrl": { "type": "string" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two or more users.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["direct", "group"] },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" },
        "createdBy": { "type": "string" }
      },
      "required": ["type", "participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "audio", "image", "file", "nudge"] },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "readBy": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["chatId", "senderId", "type", "createdAt"]
    },
    "TypingIndicator": {
      "title": "TypingIndicator",
      "description": "Indicates if a user is typing in a chat.",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["isTyping", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and settings."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores chat metadata and participants."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages for a specific chat."
    },
    "/chats/{chatId}/typing/{userId}": {
      "schema": { "$ref": "#/entities/TypingIndicator" },
      "description": "Stores typing status for users in a chat."
    }
  }
}
